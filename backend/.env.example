# Copy this file to .env and fill in values you want to override.
# .env is gitignored.

# --- Django ---
# DJANGO_SECRET_KEY=change-me-in-production
# DJANGO_DEBUG=1
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database ---
# Leave unset (or set to "sqlite") to use SQLite at backend/db.sqlite3.
# Set to "postgres" to use PostgreSQL (psycopg already installed).
# DB_ENGINE=sqlite

# PostgreSQL settings (only used when DB_ENGINE=postgres)
# DB_NAME=falcon
# DB_USER=postgres
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=5432

# --- CORS ---
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- JMeter ---
# Apache JMeter version. Tool lives at backend/jmeter/apache-jmeter-<VERSION>/,
# auto-downloaded on first use (no env override — project-local by design).
# For Docker, extract JMeter to this same path at image build time.
# JMETER_VERSION=5.4.1

# --- InfluxDB v1.x (Step 3 实时指标管道) ---
# JMeter Backend Listener 直接写入；后端只读查询。
# 启用方法：docker compose -f backend/docker-compose.dev.yml up -d
# 然后 ./venv/bin/python manage.py setup_influxdb 建库 + 保留策略。
# INFLUXDB_URL=http://localhost:8086
# INFLUXDB_DB=jmeter
# INFLUXDB_USER=falcon
# INFLUXDB_PASSWORD=falcon-dev
# INFLUXDB_RETENTION=30d

# ── AI 压测分析（Step 4「AI 分析」按钮）──
# qoder 是桌面 IDE、无官方 HTTP API：需一个 OpenAI 兼容端点（社区 qoder-proxy
# 把 pt- 密钥包装成 /v1/chat/completions）。也可填任意 OpenAI 兼容网关。
# 留空 = AI 按钮提示「未配置」，算法结论照常。
# AI_BASE_URL=http://localhost:3000/v1
# AI_API_KEY=pt-xxxxxxxx
# AI_MODEL=auto
# AI_TIMEOUT=90
